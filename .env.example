# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/estimateos

# JWT Authentication
JWT_SECRET_KEY=your-secret-key-change-in-production-use-long-random-string

# Anthropic AI
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Frontend URL (for CORS)
FRONTEND_URL=https://estimateos-pro.vercel.app

# AWS S3 (Optional - for file storage)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
S3_BUCKET_NAME=estimateos-uploads
AWS_REGION=us-east-1

# Application Settings
PORT=8000
ENVIRONMENT=production
DEBUG=false

# Tesseract OCR Path (if needed)
# TESSERACT_CMD=/usr/bin/tesseract
